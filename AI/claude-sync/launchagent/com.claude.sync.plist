<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  com.claude.sync.plist
  Place at: ~/Library/LaunchAgents/com.claude.sync.plist
  This keeps watch.sh running as a background daemon on Mac login.

  Load:    launchctl load ~/Library/LaunchAgents/com.claude.sync.plist
  Unload:  launchctl unload ~/Library/LaunchAgents/com.claude.sync.plist
  Status:  launchctl list | grep claude
  Logs:    tail -f ~/.claude/sync/sync.log
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.claude.sync</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-l</string>
    <string>-c</string>
    <string>exec bash "$HOME/.claude/sync/watch.sh"</string>
  </array>

  <!-- Start automatically at login -->
  <key>RunAtLoad</key>
  <true/>

  <!-- Restart if it crashes -->
  <key>KeepAlive</key>
  <true/>

  <!-- Throttle restarts to avoid spin loops -->
  <key>ThrottleInterval</key>
  <integer>10</integer>

  <!-- Log output -->
  <key>StandardOutPath</key>
  <string>/Users/REPLACE_WITH_USERNAME/.claude/sync/launchd-stdout.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/REPLACE_WITH_USERNAME/.claude/sync/launchd-stderr.log</string>

  <!-- Run with your user environment -->
  <key>EnvironmentVariables</key>
  <dict>
    <key>HOME</key>
    <string>/Users/REPLACE_WITH_USERNAME</string>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>
</dict>
</plist>
